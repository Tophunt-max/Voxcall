# ─── Build outputs ─────────────────────────────────────────────
dist/
tmp/
out-tsc/
*.tsbuildinfo
static-build/

# ─── Dependencies ───────────────────────────────────────────────
node_modules/

# ─── Environment & Secrets (NEVER commit these) ─────────────────
.env
.env.*
!.env.example
.dev.vars
*.vars

# ─── Expo / React Native ────────────────────────────────────────
.expo/
.expo-shared/

# ─── Cloudflare Wrangler ────────────────────────────────────────
.wrangler/

# ─── IDE & Editor ───────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace

# ─── OS files ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ───────────────────────────────────────────────────────
npm-debug.log*
yarn-error.log*

# ─── Test / Coverage ────────────────────────────────────────────
coverage/

