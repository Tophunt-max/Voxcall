{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:admin": "pnpm --filter @workspace/admin-panel build",
    "build:user": "pnpm --filter @workspace/voxlink build",
    "build:host": "pnpm --filter @workspace/voxlink-host build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "workerd",
      "sharp",
      "esbuild"
    ],
    "overrides": {
      "undici": "^6.27.0",
      "protobufjs": "^7.6.1",
      "@grpc/grpc-js": "^1.9.16",
      "@xmldom/xmldom": "^0.8.13",
      "fast-uri": "^3.1.2",
      "defu": "^6.1.5",
      "shell-quote": "^1.8.4",
      "@babel/core": "^7.29.6",
      "lodash": "^4.18.0",
      "vite@>=7.0.0 <7.3.5": "^7.3.5",
      "vite@<=6.4.2": "^6.4.3",
      "ws@>=8.0.0 <8.21.0": "^8.21.0",
      "ws@>=7.0.0 <7.5.11": "^7.5.11",
      "ws@>=6.0.0 <6.2.4": "^6.2.4",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4"
    }
  },
  "dependencies": {
    "@replit/connectors-sdk": "^0.3.0"
  }
}
