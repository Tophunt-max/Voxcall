{
  "expo": {
    "name": "VoxLink - Voice & Video Connection",
    "slug": "voxlink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "voxlink",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "VoxLink needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "VoxLink needs microphone access for calls."
      }
    },
    "android": {
      "permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "VoxLink needs camera access for video calls.",
          "microphonePermission": "VoxLink needs microphone access for calls.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "assetBundlePatterns": [
      "assets/**",
      "assets/icons/**",
      "assets/images/**",
      "assets/lottie/**"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
