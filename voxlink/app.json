{
  "expo": {
    "name": "VoxLink - Voice & Video Connection",
    "slug": "vixcalls",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "voxlink",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "enabled": true,
      "url": "https://ota.ssunilkumarmohanta3.workers.dev/manifest/user",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.voxlink.app",
      "associatedDomains": [
        "applinks:voxlink.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "VoxLink needs camera access for video calls so the other person can see you.",
        "NSMicrophoneUsageDescription": "VoxLink needs microphone access for audio and video calls.",
        "NSPhotoLibraryUsageDescription": "VoxLink needs access to your photos to upload profile pictures and KYC documents.",
        "NSPhotoLibraryAddUsageDescription": "VoxLink needs permission to save photos to your library.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.voxlink.app",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "voxlink.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://voxcall.pages.dev/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      [
        "expo-camera",
        {
          "cameraPermission": "VoxLink needs camera access for video calls so the other person can see you.",
          "microphonePermission": "VoxLink needs microphone access for audio and video calls.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "VoxLink needs access to your photos to upload profile pictures and KYC documents.",
          "cameraPermission": "VoxLink needs camera access to take profile photos."
        }
      ]
    ],
    "assetBundlePatterns": [
      "assets/**",
      "assets/icons/**",
      "assets/images/**",
      "assets/lottie/**"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "0e529a27-fcf1-4850-a306-971ef07dd2ac"
      }
    }
  }
}
