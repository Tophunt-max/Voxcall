# Copy this file to .dev.vars for local Wrangler dev only
# In production, secrets are set via: wrangler secret put <NAME>

JWT_SECRET=your-strong-random-secret-min-32-chars

# ── Agora RTC (the media provider) ───────────────────────────────────────────
# BOTH are REQUIRED — Agora is the only RTC transport. /api/calls/initiate and
# /health report rtc_provider="agora" and the client joins via
# /api/calls/:id/agora-token.
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-primary-certificate

# Marks local dev as NOT production. Omit/keep as "development" in dev.
ENVIRONMENT=development
