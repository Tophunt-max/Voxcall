modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "VoxLink - Voice & Video Connection"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "VoxLink Admin Panel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "VoxLink Gateway"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "voxlink-host: expo"

[[workflows.workflow]]
name = "VoxLink - Voice & Video Connection"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 BASE_PATH=/ pnpm --filter @workspace/voxlink run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "VoxLink Admin Panel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/admin-panel/ pnpm --filter @workspace/admin-panel run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "VoxLink Gateway"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PROXY_PORT=3000 node proxy-server.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "voxlink-host: expo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/voxlink-host run dev"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
EXPO_PUBLIC_FIREBASE_VAPID_KEY = "BA169KXMPc3JsGE64NRFeibiuxRCPfphnVroydDaG69iL4HYuhMqA1hKx3e-b5wAWhgqcBS_mIcO8Yz428do63E"
